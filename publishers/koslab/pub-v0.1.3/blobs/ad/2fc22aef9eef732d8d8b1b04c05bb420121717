### 2.3 Nuevo método en `GraduationEngine`

**`ckl-temporal/src/graduation.rs`**:
```rust
impl GraduationEngine {
    pub fn publish_to_aether(
        &self,
        block_id: BlockId,
        source_session: EntityId,
        aether_source: SourceId,
        gate: GraduationGate,
    ) -> Result<GraduationOutcome> {
        // 1. Resolver target entity
        let aether_entity = self.resolve_aether_entity(aether_source)?
            .ok_or(Error::SourceNotBoundToEntity)?;

        // 2. Reusar pipeline existente con reason específico
        self.graduate_with_reason(
            block_id,
            source_session,
            aether_entity,
            gate,
            GraduationReason::PublishedToAether,
        )
    }

    fn resolve_aether_entity(&self, source_id: SourceId) -> Result<Option<EntityId>> {
        let source = self.storage.get_source(source_id)?;
        Ok(source.entity_id)
    }
}
```


### 2.5 Criterio de aceptación

```rust
#[test]
fn publish_to_aether_local_with_dedup() {
    let workspace = TestWorkspace::new();

    // Setup publisher: project + aether source (auto-bind entity)
    let project = workspace.create_project("aether-pubs");
    let source = workspace.execute(Intent::UpsertSource {
        name: "react", kind: SourceKind::Aether,
        project_id: Some(project), entity_id: None,
    }).unwrap();
    let aether_entity = workspace.get_source(source).entity_id.unwrap();

    // Sesión con un block + 3 atomos
    let session = workspace.create_session_entity();
    let block = workspace.add_block(session, vec!["fact1", "fact2", "fact3"]);

    // PRIMER publish → atomos novel, todos a Layer::Low
    let outcome1 = workspace.publish_to_aether(block, session, source, gate());
    assert!(matches!(outcome1, GraduationOutcome::Graduated { .. }));
    assert_eq!(workspace.atom_count(aether_entity), 3);

    // SEGUNDO publish del mismo block → todos los atomos hacen match → Reinforced
    let outcome2 = workspace.publish_to_aether(block, session, source, gate());
    assert!(matches!(outcome2, GraduationOutcome::Reinforced { .. }));
    assert_eq!(workspace.atom_count(aether_entity), 3);  // sin duplicar

    // GraduationRecord persistido con reason correcto
    let records = workspace.records_by_entity(aether_entity);
    assert!(records.iter().all(|r|
        matches!(r.provenance.reason, GraduationReason::PublishedToAether)
    ));

    // El aether_entity puede emitir un slice válido
    let slice = workspace.commit_slice(aether_entity, "first publish").unwrap();
    assert_eq!(slice.hash_version, 2);
    workspace.verify_slice(slice).unwrap();
}
```


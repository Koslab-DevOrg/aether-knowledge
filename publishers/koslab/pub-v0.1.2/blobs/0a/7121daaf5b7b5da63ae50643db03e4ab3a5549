name: Publish Aether Packages

on:
  workflow_dispatch:        # trigger manual
  repository_dispatch:      # trigger desde otro repo (KOSLAB workspace)
    types: [aether-publish]

jobs:
  publish:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install ckl
